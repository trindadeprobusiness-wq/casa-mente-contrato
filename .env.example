# =========================================================================
# Oliver CRM — variáveis de ambiente do FRONTEND (prefixo VITE_)
# -------------------------------------------------------------------------
# Copie este arquivo para `.env` no desenvolvimento local.
# Na Vercel: Project → Settings → Environment Variables (cadastre os mesmos
# nomes nos ambientes Production, Preview e Development).
#
# ATENÇÃO: tudo que tem prefixo VITE_ é embutido no bundle e fica VISÍVEL
# no navegador. Nunca coloque segredos de servidor (service_role, chaves
# privadas de IA, tokens de webhook) aqui — esses ficam no Supabase.
# =========================================================================

# --- Supabase (obrigatório) ---
VITE_SUPABASE_URL=https://SEU-PROJETO.supabase.co
# A "publishable/anon key" do Supabase. Os dois nomes abaixo recebem o MESMO
# valor (há dois clients no código usando nomes diferentes).
VITE_SUPABASE_PUBLISHABLE_KEY=sua-anon-key-publica
VITE_SUPABASE_ANON_KEY=sua-anon-key-publica

# --- UTMify (rastreamento de conversões — opcional) ---
VITE_UTMIFY_WEBHOOK_URL=

# =========================================================================
# Segredos do BACKEND (Supabase Edge Functions) — NÃO vão aqui.
# Configure-os com `supabase secrets set` ou no Dashboard do Supabase:
#   GROK_API_KEY            -> IA (assistente, contratos, WhatsApp)
#   GEMINI_API_KEY          -> análise de fotos (Edge Function analisar-foto)
#   SUPABASE_SERVICE_ROLE_KEY
#   ASAAS_WEBHOOK_TOKEN     -> webhook de pagamentos Asaas
#   N8N_SHARED_SECRET       -> integração n8n
# (LOVABLE_API_KEY foi REMOVIDA — não é mais necessária.)
# =========================================================================
